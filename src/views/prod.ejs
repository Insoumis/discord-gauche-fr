<!DOCTYPE html>
<html lang="fr">

<head>
    <%- include('components/head', {title: `${post.title}` , image: `/covers/${post.id}.png`, card: "summary_large_image" , description:
        `${post.description}` }); %>
        <style>
            body {
                margin: 0;
                position: absolute;
                inset: 0;
                display: flex;
                flex-direction: column;
                background-color: var(--color-noir);
                color: var(--color-blanc);
                font-family: Grotesk;
                z-index: 1;
            }

            #banner {
                position: absolute;
                width: 100%;
                left: 0;
                right: 0;
                top: 0;
                height: 200px;
                background-position: center;
                background-size: cover;
                z-index: 0;

                @media (width >=40rem) {
                    height: 300px;
                }
            }

            #header {
                margin-top: 170px;
                margin-left: 20px;
                right: 0px;
                display: flex;
                flex-direction: row;
                z-index: 1;

                @media (width >=40rem) {
                    margin-top: 60px;
                }
            }

            #cover {
                min-width: 120px;
                min-height: 180px;
                background-position: center;
                background-size: cover;
                border-style: solid;

                @media (width >=40rem) {
                    min-width: 240px;
                    min-height: 360px;
                }
            }

            #header-infos {
                display: flex;
                flex-direction: column;
                justify-content: end;
                margin-left: 20px;
            }

            #header-infos>h1 {
                margin: 0;
                font-size: 2rem;
                font-family: Mohave;
                font-weight: bolder;
                text-transform: uppercase;
            }

            #prod-content {
                flex: 1;
                padding: 20px;
            }

            #prod-description {
                padding: 20px;
                background-color: gray;
                display: flex;
                flex-direction: row;
                align-items: center;
                gap: 20px;
                font-size: large;
            }

            #prod-description>img {
                min-width: 20px;
            }

            #prod-links {
                display: flex;
                flex-direction: row;
                flex-wrap: wrap;
                margin-top: 20px;
                gap: 20px;
            }

            .prod-link {
                background-color: var(--color-violet);
                color: var(--color-blanc);
            }

            #header-logo {
                position: absolute;
                top: 5px;
                left: 10px;
            }
        </style>
</head>

<body>
    <div id="banner" style="<%= `background-image: url( /banners/${post.id}.png );`%>"></div>

    <div id="header">
        <div id="cover" style="<%= `background-image: url( /covers/${post.id}.png );`%>"></div>
        <div id="header-infos">
            <h1 class="glow">
                <%= post.title %>
            </h1>
            <%= post.year %>
        </div>
    </div>
    <div id="prod-content">
        <p id="prod-description">
            <img src="/assets/icons/info.svg" class="icon-img" />
            <%- post.description.replace("\n", "<br /><br />") %>
        </p>
        <div id="prod-links">
            <% post.access.forEach((btn)=> {%>
                <a class="prod-link btn" href="<%= btn.link %>" target="_blank" rel="noopener noreferrer" aria-label="<%= btn.title %>">
                    <% if (btn.icon==='pointer' ) { %>
                        <img src="/assets/icons/pointer.svg" class="icon-img" />
                        <% } else if (btn.icon==='download' ) { %>
                            <img src="/assets/icons/download.svg" class="icon-img" />
                            <% } else if (btn.icon==='play' ) { %>
                                <img src="/assets/icons/play.svg" class="icon-img" />
                                <% } %>
                                    <%= btn.title %>
                </a>
                <% });%>

        </div>
    </div>

    <a id="header-logo" href="/" alt="retour" aria-label="Retour à l'accueil">
        <img src="/assets/LOGO I BARRICADE BLANC.svg" style="width: 2rem;" /><span>La Barricade</span>
    </a>
</body>

</html>